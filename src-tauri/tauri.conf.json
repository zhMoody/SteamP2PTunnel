{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "P2P Tunnel",
	"version": "0.2.2",
	"identifier": "com.moody.mcct",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Steam P2P Tunnel",
				"width": 1040,
				"height": 850,
				"decorations": false,
				"transparent": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"resources": ["steam_api64.dll"]
	}
}
