{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main and logs windows",
	"windows": ["main", "logs", "tray-popup"],
	"permissions": [
		"core:default",
		"opener:default",
		"core:event:default",
		"core:webview:default",
		{
			"identifier": "core:window:allow-close",
			"windows": ["main", "logs"]
		},
		{
			"identifier": "core:window:allow-minimize",
			"windows": ["main"]
		},
		{
			"identifier": "core:window:allow-hide",
			"windows": ["main"]
		},
		{
			"identifier": "core:window:allow-show",
			"windows": ["main", "tray-popup"]
		},
		"core:window:allow-center",
		"core:window:allow-set-focus",
		"core:window:allow-start-dragging"
	]
}
